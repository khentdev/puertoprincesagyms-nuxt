{
  "name": "backend-project",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/server.js",
    "db:reset": "prisma db reset --force",
    "compose:dev": "docker compose -f compose.dev.yaml watch",
    "compose:prod": "docker compose -f compose.prod.yaml up --build",
    "compose:down": "docker compose -f compose.dev.yaml down",
    "compose:down:prod": "docker compose -f compose.prod.yaml down",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.4.2",
    "@upstash/ratelimit": "^2.0.8",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "hono": "^4.11.4",
    "pg": "^8.17.2",
    "pino": "^9.14.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.16.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
